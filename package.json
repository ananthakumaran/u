{
    "name": "u-node",
    "version": "0.0.3",
    "description": "A library to compactly encode data which can be used in URL.",
    "type": "module",
    "files": [
        "package.json",
        "README.md",
        "LICENSE",
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "exports": {
        ".": "./dist/u.js",
        "./*": "./dist/*.js"
    },
    "main": "./dist/u.js",
    "types": "./dist/u.d.ts",
    "scripts": {
        "build": "npm run clean && tsc",
        "clean": "rm -rf ./dist/*",
        "test": "npm run build && node --test"
    },
    "keywords": [
        "url",
        "encode",
        "compression"
    ],
    "repository": {
        "type": "git",
        "url": "git://github.com/ananthakumaran/u.git"
    },
    "author": "ananthakumaran <ananthakumaran@gmail.com>",
    "license": "MIT",
    "devDependencies": {
        "@types/lodash-es": ">=4.10",
        "@types/mocha": "^10.0.6",
        "@types/node": "^24",
        "jsverify": "^0.8.4",
        "mocha": "^10.4.0",
        "prettier": "3.8.3",
        "typedoc": "^0.27.6"
    },
    "dependencies": {
        "lodash-es": ">=4.10"
    },
    "engines": {
        "node": ">=24"
    }
}
